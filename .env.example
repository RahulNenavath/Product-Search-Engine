OPENSEARCH_INITIAL_ADMIN_PASSWORD=<PASSWORD>

OPENSEARCH_HOST=opensearch
OPENSEARCH_PORT=9200
OPENSEARCH_USE_SSL=false
OPENSEARCH_VERIFY_CERTS=false
OPENSEARCH_TIMEOUT=30

OPENSEARCH_BM25_INDEX=<BM25 Index Name>
OPENSEARCH_HNSW_INDEX=<HNSW Index Name>

NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility

GCP_PROJECT=<GCP PROJECT ID>
GCP_REGION=<GCP REGION e.g. us-east4>
GCS_MODEL_BUCKET=<GCP MODELS BUCKET NAME>
GCP_CREDENDIAL_JSON_PATH=<Path to GCP credentials JSON>

CLOUDRUN_URL=<Cloud Run embedding service URL>

VERTEX_AI_MODEL_NAME=<Gemini model name e.g. gemini-3.1-flash-lite>

# Agentic search — model selection and thinking toggle
AGENT_LLM_QUERY=<Gemini model for query rewriting e.g. gemini-3.1-flash-lite>
AGENT_LLM_ASSESS=<Gemini model for result assessment e.g. gemini-3-flash-preview>
AGENT_THINKING=false

LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=<LangSmith API key>
LANGCHAIN_PROJECT=<LangSmith project name>
